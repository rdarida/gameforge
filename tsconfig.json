{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "ESNext.AsyncIterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["jest"],
    "resolveJsonModule": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["dist", "node_modules"]
}
